# EMQX Cloud broker from the MQTT Connection Information screen.
MQTT_BROKER=ssl://c8c2713f.ala.eu-central-1.emqxsl.com:8883

# Fill these in if your EMQX deployment requires authentication.
MQTT_USERNAME=
MQTT_PASSWORD=

# Optional: path to the downloaded EMQX CA certificate on your Raspberry Pi.
# Leave empty to use the operating system trust store.
MQTT_CA_CERT=
MQTT_INSECURE_SKIP_VERIFY=false

VEHICLE_ID=vehicle-001
MQTT_CLIENT_ID=raspberry-pi-vehicle-001
MQTT_TOPIC=vehicle/vehicle-001/telemetry
MQTT_ACCIDENT_TOPIC=vehicle/vehicle-001/accident
PUBLISH_INTERVAL=1s

# Starting point for the mock GPS generator. Replace with your vehicle's area,
# or later swap internal/telemetry with real GPS sensor reads.
START_LATITUDE=-1.286389
START_LONGITUDE=36.817223
